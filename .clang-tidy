---
# Conservative preset focused on real bugs + performance.
# Skip stylistic / modernize suites — they fight CommonLibSF's idioms.
# Scope to project src only (HeaderFilterRegex below).

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-reserved-identifier,
  performance-*,
  portability-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-redundant-void-arg,
  readability-const-return-type,
  readability-misleading-indentation,
  readability-redundant-smartptr-get,
  readability-string-compare,
  cppcoreguidelines-init-variables,
  cppcoreguidelines-pro-type-cstyle-cast,
  cppcoreguidelines-slicing,
  clang-analyzer-*

# Only lint this project's own source — not CommonLibSF or build artifacts.
HeaderFilterRegex: '^.*[/\\]src[/\\].*$'

WarningsAsErrors: ''

FormatStyle: file

CheckOptions:
  - key: bugprone-assert-side-effect.AssertMacros
    value: 'assert,SFSE_ASSERT'
  - key: readability-identifier-naming.IgnoreMainLikeFunctions
    value: true
